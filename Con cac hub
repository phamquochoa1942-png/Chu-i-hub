CloseBtn.Parent = TitleBar

Instance.new("UICorner").CornerRadius = UDim.new(0, 6) Parent = CloseBtn

CloseBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
end)

ToggleUIBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

local dragging, dragStart, frameStart

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        frameStart = MainFrame.Position
        input.Changed:Wait()
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

_G.FastAttackAll = false

local AutoFarmBtn = Instance.new("TextButton")
AutoFarmBtn.Size = UDim2.new(1, -30, 0, 44)
AutoFarmBtn.Position = UDim2.new(0, 15, 0, 58)
AutoFarmBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
AutoFarmBtn.Text = "AUTO FARM [OFF]"
AutoFarmBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
AutoFarmBtn.TextSize = 14
AutoFarmBtn.Font = Enum.Font.GothamSemibold
AutoFarmBtn.Parent = MainFrame

Instance.new("UICorner").CornerRadius = UDim.new(0, 8) Parent = AutoFarmBtn

AutoFarmBtn.MouseButton1Click:Connect(function()
    _G.FastAttackAll = not _G.FastAttackAll
    
    if _G.FastAttackAll then
        AutoFarmBtn.Text = "AUTO FARM [ON]"
        AutoFarmBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
        task.spawn(function()
            local ReplicatedStorage = game:GetService("ReplicatedStorage")
            local Players = game:GetService("Players")
            local VirtualInputManager = game:GetService("VirtualInputManager")
            local TweenService = game:GetService("TweenService")
            local RunService = game:GetService("RunService")
            local LocalPlayer = Players.LocalPlayer
            local AttackRemote = ReplicatedStorage.Modules.Net:FindFirstChild("RE/RegisterHit")
            
            local IsClicking = false
            local CurrentTarget = nil
            local TweenConnection = nil
            local NoFallConnection = nil
            local OriginalGravity = workspace.Gravity
            
            local function ForceReset()
                IsClicking = false
                CurrentTarget = nil
                
                if TweenConnection then
                    TweenConnection:Cancel()
                    TweenConnection = nil
                end
                
                if NoFallConnection then
                    NoFallConnection:Disconnect()
                    NoFallConnection = nil
                end
                
                workspace.Gravity = OriginalGravity
                
                local Char = LocalPlayer.Character
                if Char then
                    local Humanoid = Char:FindFirstChildOfClass("Humanoid")
                    if Humanoid then
                        Humanoid.WalkSpeed = 16
                        Humanoid.JumpPower = 50
                        Humanoid.PlatformStand = false
                        Humanoid.AutoRotate = true
                    end
                    local Root = Char:FindFirstChild("HumanoidRootPart")
                    if Root then
                        Root.Velocity = Vector3.new(0, 0, 0)
                        Root.RotVelocity = Vector3.new(0, 0, 0)
                    end
                    for _, Part in ipairs(Char:GetDescendants()) do
                        if Part:IsA("BasePart") then
                            Part.CanCollide = true
                        end
                    end
                end
            end
            
            local function StartNoFall()
                if NoFallConnection then
                    NoFallConnection:Disconnect()
                end
                
                workspace.Gravity = 0
                
                local Char = LocalPlayer.Character
                if Char then
                    local Humanoid = Char:FindFirstChildOfClass("Humanoid")
                    if Humanoid then
                        Humanoid.WalkSpeed = 0
                        Humanoid.JumpPower = 0
                        Humanoid.PlatformStand = true
                    end
                    for _, Part in ipairs(Char:GetDescendants()) do
                        if Part:IsA("BasePart") and Part.Name ~= "HumanoidRootPart" then
                            Part.CanCollide = false
                        end
                    end
                end
                
                NoFallConnection = RunService.Heartbeat:Connect(function()
                    local Char = LocalPlayer.Character
                    if Char then
                        local Root = Char:FindFirstChild("HumanoidRootPart")
                        if Root then
                            Root.Velocity = Vector3.new(0, 0, 0)
                            Root.RotVelocity = Vector3.new(0, 0, 0)
                        end
                    end
                end)
            end
            
            local function TweenToEnemy(Enemy)
                if TweenConnection then
                    TweenConnection:Cancel()
                end
                
                local Char = LocalPlayer.Character
                if not Char then return end
                
                local Root = Char:FindFirstChild("HumanoidRootPart")
                if not Root then return end
                
                local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
                if not EnemyRoot then return end
                
                StartNoFall()
                
                local TargetPos = EnemyRoot.Position + Vector3.new(0, 10, 0)
                local Distance = (Root.Position - TargetPos).Magnitude
                local Speed = math.clamp(Distance / 100, 0.2, 0.8)
                
                local Tween = TweenService:Create(Root, TweenInfo.new(Speed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(TargetPos)})
                Tween:Play()
                TweenConnection = Tween
            end
            
            task.spawn(function()
                while _G.FastAttackAll do
                    if IsClicking then
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                        task.wait()
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                        task.wait()
                    else
                        task.wait(0.05)
                    end
                end
            end)
            
            while _G.FastAttackAll do
                local Character = LocalPlayer.Character
                if not Character then
                    ForceReset()
                    task.wait(0.5)
                    continue
                end
                
                local Root = Character:FindFirstChild("HumanoidRootPart")
                if not Root then
                    ForceReset()
                    task.wait(0.5)
                    continue
                end
                
                local Humanoid = Character:FindFirstChildOfClass("Humanoid")
                if not Humanoid or Humanoid.Health <= 0 then
                    ForceReset()
                    task.wait(0.5)
                    continue
                end
                
                local Enemies = workspace:FindFirstChild("Enemies")
                if not Enemies then
                    ForceReset()
                    task.wait(0.5)
                    continue
                end
                
                local HasEnemyNearby = false
                local ClosestEnemy = nil
                local ClosestDistance = math.huge
                
                for _, Enemy in ipairs(Enemies:GetChildren()) do
                    if not _G.FastAttackAll then break end
                    if not Enemy:IsA("Model") then continue end
                    
                    local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
                    local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
                    if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot then continue end
                    
                    local Distance = (Root.Position - EnemyRoot.Position).Magnitude
                    if Distance <= 150 then
                        HasEnemyNearby = true
                        if Distance < ClosestDistance then
                            ClosestDistance = Distance
                            ClosestEnemy = Enemy
                        end
                    end
                end
                
                if HasEnemyNearby and ClosestEnemy then
                    IsClicking = true
                    
                    if CurrentTarget ~= ClosestEnemy then
                        CurrentTarget = ClosestEnemy
                        TweenToEnemy(ClosestEnemy)
                    end
                    
                    local EnemyRoot = ClosestEnemy:FindFirstChild("HumanoidRootPart")
                    if EnemyRoot then
                        Root.CFrame = EnemyRoot.CFrame * CFrame.new(0, 10, 0)
                        Root.Velocity = Vector3.new(0, 0, 0)
                    end
                    
                    for _, Enemy in ipairs(Enemies:GetChildren()) do
                        if not _G.FastAttackAll then break end
                        if not Enemy:IsA("Model") then continue end
                        
                        local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
                        local EnemyRoot2 = Enemy:FindFirstChild("HumanoidRootPart")
                        if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot2 then continue end
                        
                        local Distance = (Root.Position - EnemyRoot2.Position).Magnitude
                        if Distance > 20 then continue end
                        
                        local TargetPart = Enemy:FindFirstChild("LeftFoot") or Enemy:FindFirstChild("RightFoot") or Enemy:FindFirstChild("Head") or EnemyRoot2
                        
                        local args = {
                            [1] = TargetPart,
                            [2] = {},
                            [4] = "079baa9c"
                        }
                        
                        AttackRemote:FireServer(unpack(args))
                    end
                else
                    ForceReset()
                end
                
                task.wait()
            end
        end)
    else
        AutoFarmBtn.Text = "AUTO FARM [OFF]"
        AutoFarmBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    end
end) 
