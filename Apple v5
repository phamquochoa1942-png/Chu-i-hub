local farmCoroutine = nil
local function updateFarm()
    if farmCoroutine then task.cancel(farmCoroutine) farmCoroutine = nil end
    if _G.AutoFarm or _G.AutoMaterial then
        farmCoroutine = task.spawn(function()
            while true do
                pcall(function()
                    game:GetService("VirtualUser"):CaptureController()
                    game:GetService("VirtualUser"):ClickButton1(Vector2.new(50, 50))
                    if _G.BringMob then
                        local enemies = game:GetService("Workspace").Enemies:GetChildren()
                        for _, v in pairs(enemies) do
                            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                                v.HumanoidRootPart.CanCollide = false
                                v.HumanoidRootPart.CFrame = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                                v.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                            end
                        end
                    end
                end)
                task.wait()
            end
        end)
    end
end

local Pages = {}
local function CreatePage(name)
    local PageFrame = Instance.new("ScrollingFrame")
    PageFrame.Name = name.."_Page"
    PageFrame.Parent = RightContent
    PageFrame.Size = UDim2.new(1, 0, 1, 0)
    PageFrame.BackgroundTransparency = 1
    PageFrame.Visible = false
    PageFrame.ScrollBarThickness = 2
    
    local PageLayout = Instance.new("UIListLayout")
    PageLayout.Parent = PageFrame
    PageLayout.Padding = UDim.new(0, 8)
    
    local TabBtn = Instance.new("TextButton")
    TabBtn.Parent = TabContainer
    TabBtn.Size = UDim2.new(1, -10, 0, 35)
    TabBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    TabBtn.Text = "  " .. name
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabBtn.TextXAlignment = Enum.TextXAlignment.Left
    TabBtn.Font = Enum.Font.Gotham
    TabBtn.TextSize = 14
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
        PageFrame.Visible = true
    end)
    
    Pages[name] = PageFrame
    return PageFrame
end

local function AddToggle(parent, text, default, callback)
    local TglFrame = Instance.new("TextButton")
    TglFrame.Size = UDim2.new(1, -10, 0, 40)
    TglFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    TglFrame.Text = "  " .. text
    TglFrame.TextColor3 = Color3.fromRGB(255, 255, 255)
    TglFrame.TextXAlignment = Enum.TextXAlignment.Left
    TglFrame.Parent = parent
    Instance.new("UICorner", TglFrame).CornerRadius = UDim.new(0, 6)
    
    local Status = Instance.new("Frame")
    Status.Size = UDim2.new(0, 40, 0, 20)
    Status.Position = UDim2.new(1, -50, 0.5, -10)
    Status.BackgroundColor3 = default and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
    Status.Parent = TglFrame
    Instance.new("UICorner", Status).CornerRadius = UDim.new(1, 0)

    local val = default
    TglFrame.MouseButton1Click:Connect(function()
        val = not val
        Status.BackgroundColor3 = val and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
        callback(val)
    end)
end

