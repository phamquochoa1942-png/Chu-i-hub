_G.FastAttackAll = true

task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local LocalPlayer = Players.LocalPlayer
    local AttackRemote = ReplicatedStorage.Modules.Net:FindFirstChild("RE/RegisterHit")
    
    task.spawn(function()
        while _G.FastAttackAll do
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            task.wait(0.05)
        end
    end)
    
    while _G.FastAttackAll do
        local Character = LocalPlayer.Character
        if not Character then task.wait(0.1) continue end
        
        local Root = Character:FindFirstChild("HumanoidRootPart")
        if not Root then task.wait(0.1) continue end
        
        local Enemies = workspace:FindFirstChild("Enemies")
        if not Enemies then task.wait(0.1) continue end
        
        for _, Enemy in ipairs(Enemies:GetChildren()) do
            if not _G.FastAttackAll then break end
            if not Enemy:IsA("Model") then continue end
            
            local Humanoid = Enemy:FindFirstChildOfClass("Humanoid")
            local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
            if not Humanoid or Humanoid.Health <= 0 or not EnemyRoot then continue end
            
            local Distance = (Root.Position - EnemyRoot.Position).Magnitude
            if Distance > 50 then continue end
            
            local TargetPart = Enemy:FindFirstChild("LeftFoot") or Enemy:FindFirstChild("RightFoot") or Enemy:FindFirstChild("Head") or EnemyRoot
            
            local args = {
                [1] = TargetPart,
                [2] = {},
                [4] = "079baa9c"
            }
            
            AttackRemote:FireServer(unpack(args))
        end
        
        task.wait(0.05)
    end
end)
