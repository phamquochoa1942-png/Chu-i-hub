_G.FastAttackAll = true

task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local TweenService = game:GetService("TweenService")
    local LocalPlayer = Players.LocalPlayer
    local AttackRemote = ReplicatedStorage.Modules.Net:FindFirstChild("RE/RegisterHit")
    
    local IsClicking = false
    local CurrentTarget = nil
    local TweenConnection = nil
    local NoFallConnection = nil
    local OriginalGravity = workspace.Gravity
    
    local function StopNoFall()
        if NoFallConnection then
            NoFallConnection:Disconnect()
            NoFallConnection = nil
        end
        workspace.Gravity = OriginalGravity
        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.JumpPower = 50
                Humanoid.HipHeight = 0
            end
        end
    end
    
    local function StartNoFall()
        StopNoFall()
        workspace.Gravity = 9e9
        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.JumpPower = 0
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") then
                    Part.CanCollide = false
                end
            end
        end
        NoFallConnection = game:GetService("RunService").Heartbeat:Connect(function()
            local Char = LocalPlayer.Character
            if Char then
                local Root = Char:FindFirstChild("HumanoidRootPart")
                if Root then
                    Root.Velocity = Vector3.new(0, 9e9, 0)
                    Root.RotVelocity = Vector3.new(0, 0, 0)
                end
                for _, Part in ipairs(Char:GetDescendants()) do
                    if Part:IsA("BasePart") then
                        Part.CanCollide = false
                    end
                end
            end
        end)
    end
    
    local function TweenToEnemy(Enemy)
        if TweenConnection then TweenConnection:Disconnect() end
        local Char = LocalPlayer.Character
        if not Char then return end
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if not Root then return end
        local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
        if not EnemyRoot then return end
        
        StartNoFall()
        
        local TargetPos = EnemyRoot.Position + Vector3.new(0, 8, 0)
        local Distance = (Root.Position - TargetPos).Magnitude
        local Speed = math.clamp(Distance / 50, 0.3, 1.5)
        
        local Tween = TweenService:Create(Root, TweenInfo.new(Speed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(TargetPos)})
        Tween:Play()
        
        TweenConnection = Tween
        Tween.Completed:Connect(StopNoFall)
    end
    
    task.spawn(function()
        while _G.FastAttackAll do
            if IsClicking then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            end
            task.wait()
        end
    end)
    
    while _G.FastAttackAll do
        local Character = LocalPlayer.Character
        if not Character then 
            IsClicking = false
            CurrentTarget = nil
            StopNoFall()
            task.wait(0.05) 
            continue 
        end
        
        local Root = Character:FindFirstChild("HumanoidRootPart")
        if not Root then 
            IsClicking = false
            CurrentTarget = nil
            StopNoFall()
            task.wait(0.05) 
            continue 
        end
        
        local Enemies = workspace:FindFirstChild("Enemies")
        if not Enemies then 
            IsClicking = false
            CurrentTarget = nil
            StopNoFall()
            task.wait(0.05) 
            continue 
        end
        
        local HasEnemyNearby = false
        local ClosestEnemy = nil
        local ClosestDistance = math.huge
        
        for _, Enemy in ipairs(Enemies:GetChildren()) do
            if not Enemy:IsA("Model") then continue end
            local Humanoid = Enemy:FindFirstChildOfClass("Humanoid")
            local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
            if not Humanoid or Humanoid.Health <= 0 or not EnemyRoot then continue end
            
            local Distance = (Root.Position - EnemyRoot.Position).Magnitude
            if Distance <= 100 then
                HasEnemyNearby = true
                if Distance < ClosestDistance then
                    ClosestDistance = Distance
                    ClosestEnemy = Enemy
                end
            end
        end
        
        if HasEnemyNearby and ClosestEnemy then
            if CurrentTarget ~= ClosestEnemy then
                CurrentTarget = ClosestEnemy
                TweenToEnemy(ClosestEnemy)
            end
            
            local EnemyRoot = ClosestEnemy:FindFirstChild("HumanoidRootPart")
            if EnemyRoot then
                Root.CFrame = EnemyRoot.CFrame * CFrame.new(0, 8, 0)
            end
            
            local BodyParts = {"LeftFoot", "RightFoot", "LeftLeg", "RightLeg", "LeftArm", "RightArm", "Head", "HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso"}
            local TargetPart = nil
            
            for _, PartName in ipairs(BodyParts) do
                local Part = ClosestEnemy:FindFirstChild(PartName)
                if Part then
                    TargetPart = Part
                    break
                end
            end
            
            if not TargetPart then TargetPart = EnemyRoot end
            
            local args = {
                [1] = TargetPart,
                [2] = {},
                [4] = "079baa9c"
            }
            
            AttackRemote:FireServer(unpack(args))
        else
            CurrentTarget = nil
            StopNoFall()
            if TweenConnection then
                TweenConnection:Cancel()
                TweenConnection = nil
            end
        end
        
        IsClicking = HasEnemyNearby
        
        task.wait()
    end
end)
