-- [[ LOGIC VẬN HÀNH TÁCH BIỆT - DỨT ĐIỂM GIẬT NÚT ]]

-- Logic Farm & Material (Thread kiểm soát gắt gao)
task.spawn(function()
    while true do
        task.wait(0.01)
        if _G.AutoFarm or _G.AutoMaterial then
            pcall(function()
                -- Cơ chế Dừng Cứng: Nếu cả 2 đều false thì thoát pcall ngay
                if not _G.AutoFarm and not _G.AutoMaterial then return end
                
                game:GetService("VirtualUser"):CaptureController()
                game:GetService("VirtualUser"):ClickButton1(Vector2.new(50, 50))
                
                if _G.BringMob then
                    for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                        -- Kiểm tra biến liên tục trong loop để ngắt giật nút
                        if not _G.AutoFarm and not _G.AutoMaterial then break end
                        
                        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                            v.HumanoidRootPart.CanCollide = false
                            v.HumanoidRootPart.CFrame = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                            v.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                        end
                    end
                end
            end)
        end
    end
end)

-- Logic Rương riêng
task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.AutoChest then
            for i,v in pairs(game:GetService("Workspace"):GetChildren()) do
                if not _G.AutoChest then break end 
                if v.Name:find("Chest") then
                    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = v.CFrame
                    task.wait(0.15) 
                end
            end
        end
    end
end)

-- Logic Dash
task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.InfiniteDash then
            pcall(function()
                debug.setupvalue(getrenv()._G.Characters.Dash, 3, 0)
            end)
        end
    end
end)

