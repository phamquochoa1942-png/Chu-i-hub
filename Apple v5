_G.FastAttackAll = true
_G.BringMob = true

task.spawn(function()
    while _G.BringMob do
        local player = game.Players.LocalPlayer
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local root = char.HumanoidRootPart
            for _, v in pairs(workspace.Enemies:GetChildren()) do
                if v:IsA("Model") then
                    local hum = v:FindFirstChildOfClass("Humanoid")
                    local hrp = v:FindFirstChild("HumanoidRootPart")
                    if hum and hum.Health > 0 and hrp then
                        if (root.Position - hrp.Position).Magnitude <= 200 then
                            hrp.CFrame = root.CFrame * CFrame.new(0, 0, -5)
                        end
                    end
                end
            end
        end
        task.wait()
    end
end)

task.spawn(function()
    while _G.FastAttackAll do
        for _, v in pairs(workspace.enemies:Children()) do
            local humanoid = v:FindFirstChildOfClass("humanoid")
            local rootPart = v:FindFirstChild("HumanrootPart")
            if v:lsA("model") and humanoid and humanoid.Health > 0 and rootPart then
                local playerPart = game.Players.LocalPlayer.Character.HumanoidRootPart
                local magnitude = (playerPart.Position - rootPart.Position).magnitude
                if magnitude < 50 then
                    _G.FastAttackAll = true
                    task.spawn(function()
                        while _G.FastAttackAll do
                            for _, v in pairs(workspace.Enemies:GetChildren()) do
                                local humanoid = v:FindFirstChildOfClass("Humanoid")
                                local rootPart = v:FindFirstChild("HumanoidRootPart")
                                if v:IsA("Model") and humanoid and humanoid.Health > 0 and rootPart then
                                    local playerPart = game.Players.LocalPlayer.Character.HumanoidRootPart
                                    local magnitude = (playerPart.Position - rootPart.Position).Magnitude
                                    if magnitude < 50 then
                                        local args = {
                                            [1] = v:FindFirstChild("RightUpperLeg") or rootPart,
                                            [2] = {},
                                            [4] = "079004b0"
                                        }
                                        game:GetService("ReplicatedStorage").Modules.Net:FindFirstChild("RE/RegisterHit"):FireServer(unpack(args))
                                    end
                                end
                            end
                            task.wait(0.05)
                        end
                    end)
                end
            end
        end
        task.wait(0.05)
    end
end) 
