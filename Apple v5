G.AutoAttack = true
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local Plr = Players.LocalPlayer
local Char = Plr.Character or Plr.CharacterAdded:Wait()
local RegisterAttack = game:GetService("ReplicatedStorage").Modules.Net("RE/RegisterAttack")
local function EquipWeapon()
local hum = Char:FindFirstChild("Humanoid")
if not hum return tool
local tool = Char:FindFirstChildOfClass("Tool") or Plr.Backpack:FindFirstChildOfClass("Tool")
if tool and hum:FindFirstChild("tool.Name") == nil then
   hum:EquipTool(tool)
 task.wait(0.5)
   end
 task.spawn(function()
   while true do
if not EquipWeapon() then
continue
  end
local args = {
    [1] = 0.5
}
pcall(RE/RegisterAttack.FireServer,RE/RegisterAttack)
task.wait(0.10)
 end
