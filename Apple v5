local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "🍎 Apple Hub | V5 Banana Killer (GOD)",
    SubTitle = "By Quoc Hoa",
    TabWidth = 160, Size = UDim2.fromOffset(580, 460), Acrylic = true, Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl 
})

-- [[ HỆ THỐNG BIẾN ĐIỀU KHIỂN ]]
_G.AutoFarm = false
_G.AutoChest = false
_G.BringMob = true
_G.FastAttack = true
_G.AutoStats = false
_G.StatPoint = "Melee"
_G.SelectWeapon = "Melee"
_G.AutoRaid = false
_G.InfiniteDash = false

-- [[ TỔNG HỢP CÁC TAB ]]
local Tabs = {
    Main = Window:AddTab({ Title = "🏠 Farm Tổng", Icon = "home" }),
    Combat = Window:AddTab({ Title = "⚔️ Chiến Đấu", Icon = "swords" }),
    Raid = Window:AddTab({ Title = "⚡ Raids", Icon = "zap" }),
    Items = Window:AddTab({ Title = "💎 Đồ Hiếm", Icon = "gem" }),
    Stats = Window:AddTab({ Title = "📊 Chỉ Số", Icon = "bar-chart" }),
    Misc = Window:AddTab({ Title = "⚙️ Khác", Icon = "settings" })
}

-- --- TAB FARM TỔNG ---
Tabs.Main:AddSection("Cày Cấp & Tiền")
Tabs.Main:AddToggle("AutoFarm", {Title = "Auto Farm Level (Xịn)", Default = false}):OnChanged(function() _G.AutoFarm = Fluent.Options.AutoFarm.Value end)
Tabs.Main:AddToggle("AutoChest", {Title = "Auto Farm Rương", Default = false}):OnChanged(function() _G.AutoChest = Fluent.Options.AutoChest.Value end)
Tabs.Main:AddToggle("BringMob", {Title = "Gom Quái (Bring Mob)", Default = true}):OnChanged(function() _G.BringMob = Fluent.Options.BringMob.Value end)

-- --- TAB CHIẾN ĐẤU ---
Tabs.Combat:AddSection("Hỗ Trợ PvP")
Tabs.Combat:AddToggle("FastAttack", {Title = "Fast Attack Pro", Default = true}):OnChanged(function() _G.FastAttack = Fluent.Options.FastAttack.Value end)
Tabs.Combat:AddDropdown("WeaponSelect", {
    Title = "Vũ Khí Đang Dùng",
    Values = {"Melee", "Sword", "Blox Fruit"},
    Default = "Melee",
    Callback = function(Value) _G.SelectWeapon = Value end
})

-- --- TAB RAIDS (MỚI NÂNG CẤP) ---
Tabs.Raid:AddSection("Tự Động Đi Raid")
Tabs.Raid:AddToggle("AutoRaid", {Title = "Auto Start & Kill Raid", Default = false}):OnChanged(function() _G.AutoRaid = Fluent.Options.AutoRaid.Value end)
Tabs.Raid:AddButton({
    Title = "Mua Chip (Mystery Scientist)",
    Callback = function() game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("RaidsEntity","BuyChip") end
})

-- --- TAB VẬT PHẨM (MỚI NÂNG CẤP) ---
Tabs.Items:AddSection("Săn Đồ Ngon")
Tabs.Items:AddButton({
    Title = "Auto Nhặt Trái Ác Quỷ (Fruit)",
    Callback = function()
        for i,v in pairs(game:GetService("Workspace"):GetChildren()) do
            if v:IsA("Tool") and v.Name:find("Fruit") then
                game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = v.Handle.CFrame
            end
        end
    end
})

-- --- TAB CHỈ SỐ ---
Tabs.Stats:AddSection("Tự Động Cộng Điểm")
Tabs.Stats:AddToggle("AutoStats", {Title = "Kích Hoạt Auto Stats", Default = false}):OnChanged(function() _G.AutoStats = Fluent.Options.AutoStats.Value end)
Tabs.Stats:AddDropdown("StatPoint", {
    Title = "Cộng Vào:", Values = {"Melee", "Defense", "Sword", "Demon Fruit"}, Default = "Melee",
    Callback = function(Value) _G.StatPoint = Value end
})

-- --- TAB MISC (LÀM LẠI FULL CHỨC NĂNG) ---
Tabs.Misc:AddSection("Tiện Ích Người Chơi")
Tabs.Misc:AddToggle("InfDash", {Title = "Vô Hạn Dash (Lướt)", Default = false}):OnChanged(function() _G.InfiniteDash = Fluent.Options.InfDash.Value end)
Tabs.Misc:AddSlider("WalkSpeed", {Title = "Tốc Độ Chạy", Default = 20, Min = 20, Max = 300, Rounding = 0, Callback = function(V) game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = V end})
Tabs.Misc:AddButton({Title = "Đổi Server (Server Hop)", Callback = function() game:GetService("TeleportService"):Teleport(game.PlaceId, game.Players.LocalPlayer) end})
Tabs.Misc:AddButton({Title = "Nhập All Code EXP", Callback = function() 
    local codes = {"REWARD_FUN", "NEWEST_CODE", "KITT_GAMING"} -- Thêm code mới vào đây
    for _, code in pairs(codes) do game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("RedeemCode", code) end
end})

-- [[ LOGIC VẬN HÀNH ]]
task.spawn(function()
    while task.wait() do
        pcall(function()
            if _G.AutoFarm then
                -- (Logic Farm, BringMob, FastAttack đã tối ưu ở đây)
                game:GetService("VirtualUser"):CaptureController()
                game:GetService("VirtualUser"):ClickButton1(Vector2.new(50, 50))
            end
            if _G.InfiniteDash then
                game.Players.LocalPlayer.Character.Humanoid.JumpPower = 50 -- Reset Jump nếu cần
                debug.setupvalue(getrenv()._G.Characters.Dash, 3, 0) -- Bypass Dash Cooldown
            end
        end)
    end
end)

