_G.FastAttackAll = true

task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local TweenService = game:GetService("TweenService")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer
    local AttackRemote = ReplicatedStorage.Modules.Net:FindFirstChild("RE/RegisterHit")
    
    local IsClicking = false
    local CurrentTarget = nil
    local TweenConnection = nil
    local NoFallConnection = nil
    local OriginalGravity = workspace.Gravity
    
    local function GetLocalPlayer()
        return Players.LocalPlayer
    end
    
    local function GetCharacter()
        local Player = GetLocalPlayer()
        return Player and Player.Character
    end
    
    local function StopNoFall()
        if NoFallConnection then
            NoFallConnection:Disconnect()
            NoFallConnection = nil
        end
        workspace.Gravity = OriginalGravity
        local Char = GetCharacter()
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.JumpPower = 50
                Humanoid.WalkSpeed = 16
                Humanoid.PlatformStand = false
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") then
                    Part.CanCollide = true
                end
            end
        end
    end
    
    local function StartNoFall()
        StopNoFall()
        workspace.Gravity = 0
        local Char = GetCharacter()
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.JumpPower = 0
                Humanoid.WalkSpeed = 0
                Humanoid.PlatformStand = true
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") and Part.Name ~= "HumanoidRootPart" then
                    Part.CanCollide = false
                end
            end
        end
        NoFallConnection = RunService.Heartbeat:Connect(function()
            local Char = GetCharacter()
            if Char then
                local Root = Char:FindFirstChild("HumanoidRootPart")
                if Root then
                    Root.Velocity = Vector3.new(0, 0, 0)
                    Root.RotVelocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end
    
    local function TweenToEnemy(Enemy)
        if TweenConnection then TweenConnection:Disconnect() end
        local Char = GetCharacter()
        if not Char then return end
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if not Root then return end
        local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
        if not EnemyRoot then return end
        
        StartNoFall()
        
        local TargetPos = EnemyRoot.Position + Vector3.new(0, 10, 0)
        local Distance = (Root.Position - TargetPos).Magnitude
        local Speed = math.clamp(Distance / 100, 0.2, 0.8)
        
        local Tween = TweenService:Create(Root, TweenInfo.new(Speed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(TargetPos)})
        Tween:Play()
        TweenConnection = Tween
    end
    
    local function CleanupAndReset()
        IsClicking = false
        CurrentTarget = nil
        StopNoFall()
        if TweenConnection then
            TweenConnection:Cancel()
            TweenConnection = nil
        end
        local Char = GetCharacter()
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.WalkSpeed = 16
                Humanoid.JumpPower = 50
                Humanoid.PlatformStand = false
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") then
                    Part.CanCollide = true
                end
            end
        end
    end
    
    task.spawn(function()
        while _G.FastAttackAll do
            if IsClicking then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                task.wait()
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                task.wait()
            else
                task.wait(0.05)
            end
        end
    end)
    
    while _G.FastAttackAll do
        local Player = GetLocalPlayer()
        if not Player then
            CleanupAndReset()
            task.wait(0.5)
            continue
        end
        
        local Character = Player.Character
        if not Character then
            CleanupAndReset()
            task.wait(0.5)
            continue
        end
        
        local Root = Character:FindFirstChild("HumanoidRootPart")
        if not Root then
            CleanupAndReset()
            task.wait(0.5)
            continue
        end
        
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid or Humanoid.Health <= 0 then
            CleanupAndReset()
            task.wait(0.5)
            continue
        end
        
        local Enemies = workspace:FindFirstChild("Enemies")
        if not Enemies then
            CleanupAndReset()
            task.wait(0.5)
            continue
        end
        
        local HasEnemyNearby = false
        local ClosestEnemy = nil
        local ClosestDistance = math.huge
        
        for _, Enemy in ipairs(Enemies:GetChildren()) do
            if not _G.FastAttackAll then break end
            if not Enemy:IsA("Model") then continue end
            local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
            local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
            if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot then continue end
            
            local Distance = (Root.Position - EnemyRoot.Position).Magnitude
            if Distance <= 150 then
                HasEnemyNearby = true
                if Distance < ClosestDistance then
                    ClosestDistance = Distance
                    ClosestEnemy = Enemy
                end
            end
        end
        
        if HasEnemyNearby and ClosestEnemy then
            IsClicking = true
            
            if CurrentTarget ~= ClosestEnemy then
                CurrentTarget = ClosestEnemy
                TweenToEnemy(ClosestEnemy)
            end
            
            local EnemyRoot = ClosestEnemy:FindFirstChild("HumanoidRootPart")
            if EnemyRoot then
                Root.CFrame = EnemyRoot.CFrame * CFrame.new(0, 10, 0)
                Root.Velocity = Vector3.new(0, 0, 0)
            end
            
            for _, Enemy in ipairs(Enemies:GetChildren()) do
                if not _G.FastAttackAll then break end
                if not Enemy:IsA("Model") then continue end
                local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
                local EnemyRoot2 = Enemy:FindFirstChild("HumanoidRootPart")
                if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot2 then continue end
                
                local Distance = (Root.Position - EnemyRoot2.Position).Magnitude
                if Distance > 20 then continue end
                
                local BodyParts = {"LeftFoot", "RightFoot", "LeftLeg", "RightLeg", "LeftArm", "RightArm", "Head", "HumanoidRootPart"}
                local TargetPart = nil
                
                for _, PartName in ipairs(BodyParts) do
                    local Part = Enemy:FindFirstChild(PartName)
                    if Part then
                        TargetPart = Part
                        break
                    end
                end
                
                if not TargetPart then TargetPart = EnemyRoot2 end
                
                local args = {
                    [1] = TargetPart,
                    [2] = {},
                    [4] = "079baa9c"
                }
                
                AttackRemote:FireServer(unpack(args))
            end
        else
            CleanupAndReset()
        end
        
        task.wait()
    end
end) 
