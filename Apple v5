-- [[ HÀM TẠO COMPONENT UI ]]
local Pages = {}
function CreatePage(name)
    local PageFrame = Instance.new("ScrollingFrame", RightContent)
    PageFrame.Size = UDim2.new(1, 0, 1, 0)
    PageFrame.BackgroundTransparency = 1
    PageFrame.Visible = false
    PageFrame.ScrollBarThickness = 2
    Instance.new("UIListLayout", PageFrame).Padding = UDim.new(0, 8)
    
    local TabBtn = Instance.new("TextButton", TabContainer)
    TabBtn.Size = UDim2.new(1, -10, 0, 35)
    TabBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    TabBtn.Text = "  " .. name
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabBtn.TextXAlignment = Enum.TextXAlignment.Left
    TabBtn.Font = Enum.Font.Gotham
    TabBtn.TextSize = 13
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
        PageFrame.Visible = true
    end)
    Pages[name] = PageFrame
    return PageFrame
end

function AddToggle(parent, text, default, callback)
    local Btn = Instance.new("TextButton", parent)
    Btn.Size = UDim2.new(1, -10, 0, 40)
    Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Btn.Text = "  " .. text
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    
    local Status = Instance.new("Frame", Btn)
    Status.Size = UDim2.new(0, 35, 0, 18)
    Status.Position = UDim2.new(1, -45, 0.5, -9)
    Status.BackgroundColor3 = default and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
    Instance.new("UICorner", Status).CornerRadius = UDim.new(1, 0)
    
    local val = default
    Btn.MouseButton1Click:Connect(function()
        val = not val
        Status.BackgroundColor3 = val and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
        callback(val)
    end)
end

function AddButton(parent, text, callback)
    local Btn = Instance.new("TextButton", parent)
    Btn.Size = UDim2.new(1, -10, 0, 40)
    Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Btn.Text = text
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    Btn.MouseButton1Click:Connect(callback)
end

function AddDropdown(parent, text, list, callback)
    local Label = Instance.new("TextLabel", parent)
    Label.Size = UDim2.new(1, -10, 0, 20)
    Label.Text = "  " .. text
    Label.TextColor3 = Color3.fromRGB(150, 150, 150)
    Label.BackgroundTransparency = 1
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local Drop = Instance.new("TextButton", parent)
    Drop.Size = UDim2.new(1, -10, 0, 35)
    Drop.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Drop.Text = list[1]
    Drop.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", Drop).CornerRadius = UDim.new(0, 6)
    
    Drop.MouseButton1Click:Connect(function()
        local current = table.find(list, Drop.Text) or 0
        local nextIdx = (current % #list) + 1
        Drop.Text = list[nextIdx]
        callback(list[nextIdx])
    end)
end

function AddSlider(parent, text, min, max, default, callback)
    local Container = Instance.new("Frame", parent)
    Container.Size = UDim2.new(1, -10, 0, 50)
    Container.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", Container)
    Label.Text = "  " .. text .. ": " .. default
    Label.Size = UDim2.new(1, 0, 0, 25)
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.BackgroundTransparency = 1
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local Bar = Instance.new("Frame", Container)
    Bar.Size = UDim2.new(1, 0, 0, 5)
    Bar.Position = UDim2.new(0, 0, 0, 35)
    Bar.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    
    local Fill = Instance.new("Frame", Bar)
    Fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    Fill.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    
    -- Slider logic đơn giản hóa cho mobile
    Container.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local percent = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
            local val = math.floor(min + (max - min) * percent)
            Fill.Size = UDim2.new(percent, 0, 1, 0)
            Label.Text = "  " .. text .. ": " .. val
            callback(val)
        end
    end)
end

