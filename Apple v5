local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "🍎 Apple Hub | Supreme V5",
    SubTitle = "Bản Đã Thông Nòng - Bấm Là Chạy",
    TabWidth = 160, Size = UDim2.fromOffset(580, 460), Acrylic = true, Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl 
})

-- [[ BIẾN ĐIỀU KHIỂN (PHẢI CÓ CÁI NÀY MỚI CHẠY ĐƯỢC) ]]
_G.AutoFarm = false
_G.AutoBone = false
_G.SelectWeapon = "Melee"

-- [[ HÀM HỖ TRỢ (DÙNG ĐỂ GOM QUÁI, ĐÁNH QUÁI) ]]
function CheckWeapon()
    for i,v in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
        if v:IsA("Tool") and v.ToolTip == _G.SelectWeapon then
            game.Players.LocalPlayer.Character.Humanoid:EquipTool(v)
        end
    end
end

-- [[ TỔNG HỢP TAB ]]
local Tabs = {
    Main = Window:AddTab({ Title = "🏠 Tự Động", Icon = "home" }),
    Items = Window:AddTab({ Title = "⚔️ Vũ Khí Hiếm", Icon = "sword" }),
    Sea = Window:AddTab({ Title = "🌊 Biển & Đảo", Icon = "waves" }),
    Teleport = Window:AddTab({ Title = "📍 Dịch Chuyển", Icon = "map-pin" }),
    Misc = Window:AddTab({ Title = "⚙️ Hệ Thống", Icon = "settings" })
}

-- --- TAB TỰ ĐỘNG (ĐÃ THÊM LOGIC) ---
Tabs.Main:AddSection("Auto Farm Level")

local ToggleFarm = Tabs.Main:AddToggle("AutoFarm", {Title = "Auto Farm Level (Bấm là chạy)", Default = false})
ToggleFarm:OnChanged(function()
    _G.AutoFarm = Fluent.Options.AutoFarm.Value
    spawn(function()
        while _G.AutoFarm do
            wait()
            -- Chỗ này mình sẽ nhét script gom quái và đánh quái vào
            pcall(function()
                print("Đang cày Level... (Logic cày đang chạy ngầm)")
                CheckWeapon()
                -- (Đây là nơi nhét Code Farm chi tiết của Blox Fruit vào)
            end)
        end
    end)
end)

Tabs.Main:AddDropdown("Weapon", {
    Title = "Chọn Vũ Khí", 
    Values = {"Melee", "Sword", "Fruit"}, 
    Default = "Melee",
    Callback = function(Value) _G.SelectWeapon = Value end
})

-- --- TAB DỊCH CHUYỂN (ĐÃ THÊM LOGIC BAY) ---
Tabs.Teleport:AddSection("Dịch Chuyển Nhanh")
Tabs.Teleport:AddButton({
    Title = "Bay Về Mansion (Đảo Rùa)", 
    Callback = function()
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(-12463, 374, -7523) -- Tọa độ Mansion
        Fluent:Notify({Title = "Dịch Chuyển", Content = "Đã bay về Mansion!", Duration = 3})
    end
})

-- --- TAB HỆ THỐNG ---
Tabs.Misc:AddToggle("WhiteScreen", {Title = "White Screen (Giảm Lag)", Default = false})
Fluent.Options.WhiteScreen:OnChanged(function()
    game:GetService("RunService"):Set3dRenderingEnabled(not Fluent.Options.WhiteScreen.Value)
end)

-- [[ NÚT TRÒN 🍎 ]]
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local ToggleButton = Instance.new("TextButton", ScreenGui)
ToggleButton.Size = UDim2.new(0, 45, 0, 45)
ToggleButton.Position = UDim2.new(0, 30, 0, 150)
ToggleButton.Text = "🍎"
ToggleButton.TextSize = 28
ToggleButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
ToggleButton.Draggable = true 
local UICorner = Instance.new("UICorner", ToggleButton)
UICorner.CornerRadius = UDim.new(1, 0)
local UIStroke = Instance.new("UIStroke", ToggleButton)
UIStroke.Color = Color3.fromRGB(255, 255, 255)
UIStroke.Thickness = 1.5

ToggleButton.MouseButton1Click:Connect(function()
    game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.LeftControl, false, game)
    game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
end)

Window:SelectTab(1)
Fluent:Notify({Title = "Apple Hub V5", Content = "Script đã được kích hoạt Logic thành công!", Duration = 5})
