_G.FastAttackAll = true 

-- Hàm tự động lấy vũ khí (Melee/Kiếm)
local function EquipMelee()
    local player = game.Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local backpack = player.Backpack
    
    -- Nếu trên tay chưa cầm gì thì tìm trong túi đồ
    if not character:FindFirstChildOfClass("Tool") then
        local tool = backpack:FindFirstChildOfClass("Tool")
        if tool then
            character.Humanoid:EquipTool(tool)
        end
    end
end

task.spawn(function()
    while _G.FastAttackAll do
        -- 1. Tự động cầm vũ khí lên trước khi đánh
        EquipMelee()

        -- 2. Quét quái xung quanh
        for _, v in pairs(workspace.Enemies:GetChildren()) do
            local humanoid = v:FindFirstChildOfClass("Humanoid")
            local rootPart = v:FindFirstChild("HumanoidRootPart")
            
            if v:IsA("Model") and humanoid and humanoid.Health > 0 and rootPart then
                local playerPart = game.Players.LocalPlayer.Character.HumanoidRootPart
                local magnitude = (playerPart.Position - rootPart.Position).Magnitude
                
                if magnitude < 50 then 
                    -- 3. Gửi sát thương (Logic ông đã soi)
                    local args = {
                        [1] = v:FindFirstChild("RightUpperLeg") or rootPart,
                        [2] = {},
                        [4] = "079004b0" 
                    }
                    
                    local remote = game:GetService("ReplicatedStorage").Modules.Net:FindFirstChild("RE/RegisterHit")
                    if remote then
                        remote:FireServer(unpack(args))
                    end
                end
            end
        end
        
        -- 4. Tốc độ đánh
        task.wait(0.05) 
    end
end)
 
