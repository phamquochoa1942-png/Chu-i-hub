-- M1 Kitsune Fruit — Fast Attack + Aura + Long Range
_G.KitsuneM1 = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LP = Players.LocalPlayer
local vector_create = Vector3.new

local function FireKitsuneM1(targetPos)
    local char = LP.Character
    if not char then return end
    
    local fruit = char:FindFirstChild("Kitsune-Kitsune")
    if not fruit then return end
    
    local remote = fruit:FindFirstChild("LeftClickRemote")
    if not remote then return end
    
    local direction = targetPos or (char:GetPivot().LookVector * 100)
    
    local args = {
        vector_create(direction.X, direction.Y, direction.Z),
        2,
        true
    }
    
    pcall(function()
        remote:FireServer(unpack(args))
    end)
end

local function AuraKitsune(range)
    local char = LP.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return end
    
    for _, v in ipairs(enemies:GetChildren()) do
        if v:IsA("Model") then
            local hum = v:FindFirstChildOfClass("Humanoid")
            local er = v:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and er then
                local dist = (root.Position - er.Position).Magnitude
                if dist <= (range or 200) then
                    local dir = (er.Position - root.Position).Unit * 100
                    task.spawn(function()
                        FireKitsuneM1(dir)
                    end)
                end
            end
        end
    end
end

-- =====================================================
-- MAIN LOOP — 0.01s delay
-- =====================================================
task.spawn(function()
    while _G.KitsuneM1 do
        local char = LP.Character
        if char then
            local lookDir = char:GetPivot().LookVector * 150
            FireKitsuneM1(lookDir)
            AuraKitsune(300)
        end
        
        task.wait(0.01)
    end
end)

-- Animation cancel
task.spawn(function()
    while _G.KitsuneM1 do
        task.wait(0.001)
        local char = LP.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
                    t:Stop(0)
                end
            end
        end
    end
end)

print("[Kitsune M1] ON | 0.01s delay") 
