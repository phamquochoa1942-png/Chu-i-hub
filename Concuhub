_G.FastAttackAll = true

task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local TweenService = game:GetService("TweenService")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer

    local AttackRemote = nil
    local NetFolder = ReplicatedStorage:FindFirstChild("Modules")
        and ReplicatedStorage.Modules:FindFirstChild("Net")
    if NetFolder then
        AttackRemote = NetFolder:FindFirstChild("RE/RegisterHit")
    end
    if not AttackRemote then
        for _, v in pairs(ReplicatedStorage:GetDescendants()) do
            if v:IsA("RemoteEvent") and v.Name:lower():find("hit") then
                AttackRemote = v
                print("[FastAttack] Tìm thấy Remote:", v:GetFullName())
                break
            end
        end
    end
    if not AttackRemote then
        warn("[FastAttack] Không tìm thấy Remote! Chạy hook bên dưới để tìm tên đúng.")
        for _, v in pairs(ReplicatedStorage:GetDescendants()) do
            if v:IsA("RemoteEvent") then
                local old = v.FireServer
                v.FireServer = function(self, ...)
                    print("[HOOK] REMOTE:", v:GetFullName(), "| ARGS:", ...)
                    old(self, ...)
                end
            end
        end
    end

    local IsClicking = false
    local CurrentTarget = nil
    local TweenConnection = nil
    local NoFallConnection = nil
    local StickConnection = nil
    local OriginalGravity = workspace.Gravity
    local IsActive = false

    local function ForceReset()
        IsClicking = false
        CurrentTarget = nil
        IsActive = false

        if TweenConnection then
            TweenConnection:Cancel()
            TweenConnection = nil
        end

        if NoFallConnection then
            NoFallConnection:Disconnect()
            NoFallConnection = nil
        end

        if StickConnection then
            StickConnection:Disconnect()
            StickConnection = nil
        end

        workspace.Gravity = OriginalGravity

        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.WalkSpeed = 16
                Humanoid.JumpPower = 50
                Humanoid.PlatformStand = false
                Humanoid.AutoRotate = true
            end
            local Root = Char:FindFirstChild("HumanoidRootPart")
            if Root then
                Root.Velocity = Vector3.new(0, 0, 0)
                Root.RotVelocity = Vector3.new(0, 0, 0)
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") then
                    Part.CanCollide = true
                end
            end
        end
    end

    local function StartNoFall()
        if NoFallConnection then
            NoFallConnection:Disconnect()
        end

        -- FIX: Dùng trọng lực 1e5 để giữ không rơi
        workspace.Gravity = 1e5

        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.WalkSpeed = 0
                Humanoid.JumpPower = 0
                Humanoid.PlatformStand = true
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") and Part.Name ~= "HumanoidRootPart" then
                    Part.CanCollide = false
                end
            end
        end

        NoFallConnection = RunService.Heartbeat:Connect(function()
            local Char = LocalPlayer.Character
            if Char then
                local Root = Char:FindFirstChild("HumanoidRootPart")
                if Root then
                    Root.Velocity = Vector3.new(0, 0, 0)
                    Root.RotVelocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end

    local function StickToEnemy(Enemy)
        if StickConnection then
            StickConnection:Disconnect()
            StickConnection = nil
        end

        StickConnection = RunService.Heartbeat:Connect(function()
            if not IsActive or not Enemy or not Enemy.Parent then
                StickConnection:Disconnect()
                StickConnection = nil
                return
            end

            local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
            local Char = LocalPlayer.Character
            if not EnemyRoot or not Char then return end

            local Root = Char:FindFirstChild("HumanoidRootPart")
            if not Root then return end

            local EnemyHum = Enemy:FindFirstChildOfClass("Humanoid")
            if not EnemyHum or EnemyHum.Health <= 0 then
                StickConnection:Disconnect()
                StickConnection = nil
                return
            end

            Root.CFrame = CFrame.new(EnemyRoot.Position + Vector3.new(0, 20, 0))
        end)
    end

    local function TweenToEnemy(Enemy)
        if TweenConnection then
            TweenConnection:Cancel()
        end

        local Char = LocalPlayer.Character
        if not Char then return end

        local Root = Char:FindFirstChild("HumanoidRootPart")
        if not Root then return end

        local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
        if not EnemyRoot then return end

        StartNoFall()

        local TargetPos = EnemyRoot.Position + Vector3.new(0, 20, 0)
        local Distance = (Root.Position - TargetPos).Magnitude
        local Speed = math.clamp(Distance / 250, 0.01, 0.05)

        local Tween = TweenService:Create(
            Root,
            TweenInfo.new(Speed, Enum.EasingStyle.Linear),
            {CFrame = CFrame.new(TargetPos)}
        )
        Tween:Play()
        TweenConnection = Tween

        Tween.Completed:Connect(function()
            StickToEnemy(Enemy)
        end)
    end

    RunService.Heartbeat:Connect(function()
        if _G.FastAttackAll and IsClicking then
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
        end
    end)

    task.spawn(function()
        while _G.FastAttackAll do
            if IsClicking then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            end
            task.wait(0.001)
        end
    end)

    while _G.FastAttackAll do
        local Character = LocalPlayer.Character
        if not Character then
            ForceReset()
            task.wait(0.1)
            continue
        end

        local Root = Character:FindFirstChild("HumanoidRootPart")
        if not Root then
            ForceReset()
            task.wait(0.1)
            continue
        end

        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid or Humanoid.Health <= 0 then
            ForceReset()
            task.wait(0.1)
            continue
        end

        local EnemyFolders = {}
        for _, v in pairs(workspace:GetChildren()) do
            if v:IsA("Folder") or v:IsA("Model") then
                for _, child in pairs(v:GetChildren()) do
                    if child:IsA("Model") and child:FindFirstChildOfClass("Humanoid") then
                        table.insert(EnemyFolders, v)
                        break
                    end
                end
            end
        end

        if #EnemyFolders == 0 then
            ForceReset()
            task.wait(0.1)
            continue
        end

        local HasEnemyNearby = false
        local ClosestEnemy = nil
        local ClosestDistance = math.huge
        local AllNearbyEnemies = {}

        for _, Folder in pairs(EnemyFolders) do
            for _, Enemy in pairs(Folder:GetChildren()) do
                if not _G.FastAttackAll then break end
                if not Enemy:IsA("Model") then continue end

                local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
                local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
                if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot then continue end

                local Distance = (Root.Position - EnemyRoot.Position).Magnitude
                if Distance <= 200 then
                    HasEnemyNearby = true
                    table.insert(AllNearbyEnemies, Enemy)
                    if Distance < ClosestDistance then
                        ClosestDistance = Distance
                        ClosestEnemy = Enemy
                    end
                end
            end
        end

        if HasEnemyNearby and ClosestEnemy then
            IsActive = true
            IsClicking = true

            if CurrentTarget ~= ClosestEnemy then
                CurrentTarget = ClosestEnemy
                TweenToEnemy(ClosestEnemy)
            end

            for _, Enemy in pairs(AllNearbyEnemies) do
                if not _G.FastAttackAll then break end

                local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
                local EnemyRoot2 = Enemy:FindFirstChild("HumanoidRootPart")
                if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot2 then continue end

                local Distance = (Root.Position - EnemyRoot2.Position).Magnitude
                if Distance > 50 then continue end

                local TargetPart = Enemy:FindFirstChild("LeftFoot")
                    or Enemy:FindFirstChild("RightFoot")
                    or Enemy:FindFirstChild("Head")
                    or EnemyRoot2

                if AttackRemote then
                    pcall(function()
                        AttackRemote:FireServer(TargetPart, {}, "079baa9c")
                    end)
                end
            end
        else
            ForceReset()  -- TẮT HẾT khi không có quái, MỞ LẠI khi quét được quái
        end

        task.wait()
    end
end) 
