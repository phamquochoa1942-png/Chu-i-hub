_G.FastAttackAll = true

task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local TweenService = game:GetService("TweenService")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer
    local AttackRemote = ReplicatedStorage.Modules.Net:FindFirstChild("RE/RegisterHit")
    
    local IsClicking = false
    local CurrentTarget = nil
    local TweenConnection = nil
    local NoFallConnection = nil
    local OriginalGravity = workspace.Gravity
    local IsActive = false
    local OriginalWalkSpeed = 16
    local OriginalJumpPower = 50
    
    local function ForceReset()
        IsClicking = false
        CurrentTarget = nil
        IsActive = false
        
        if TweenConnection then
            TweenConnection:Cancel()
            TweenConnection = nil
        end
        
        if NoFallConnection then
            NoFallConnection:Disconnect()
            NoFallConnection = nil
        end
        
        workspace.Gravity = OriginalGravity
        
        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.WalkSpeed = OriginalWalkSpeed
                Humanoid.JumpPower = OriginalJumpPower
                Humanoid.PlatformStand = false
                Humanoid.AutoRotate = true
            end
            local Root = Char:FindFirstChild("HumanoidRootPart")
            if Root then
                Root.Velocity = Vector3.new(0, 0, 0)
                Root.RotVelocity = Vector3.new(0, 0, 0)
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") then
                    Part.CanCollide = true
                end
            end
        end
    end
    
    local function StartNoFall()
        if NoFallConnection then
            NoFallConnection:Disconnect()
        end
        
        workspace.Gravity = 0
        
        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                OriginalWalkSpeed = Humanoid.WalkSpeed
                OriginalJumpPower = Humanoid.JumpPower
                Humanoid.WalkSpeed = 0
                Humanoid.JumpPower = 0
                Humanoid.PlatformStand = true
                Humanoid.AutoRotate = false
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") and Part.Name ~= "HumanoidRootPart" then
                    Part.CanCollide = false
                end
            end
        end
        
        NoFallConnection = RunService.Heartbeat:Connect(function()
            if not IsActive then return end
            local Char = LocalPlayer.Character
            if Char and CurrentTarget then
                local Root = Char:FindFirstChild("HumanoidRootPart")
                local EnemyRoot = CurrentTarget:FindFirstChild("HumanoidRootPart")
                if Root and EnemyRoot then
                    Root.CFrame = EnemyRoot.CFrame * CFrame.new(0, 15, 0)
                    Root.Velocity = Vector3.new(0, 0, 0)
                    Root.RotVelocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end
    
    local function TweenToEnemy(Enemy)
        if TweenConnection then
            TweenConnection:Cancel()
        end
        
        local Char = LocalPlayer.Character
        if not Char then return end
        
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if not Root then return end
        
        local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
        if not EnemyRoot then return end
        
        StartNoFall()
        
        local TargetPos = EnemyRoot.Position + Vector3.new(0, 15, 0)
        local Distance = (Root.Position - TargetPos).Magnitude
        local Speed = math.clamp(Distance / 200, 0.02, 0.1)
        
        local Tween = TweenService:Create(Root, TweenInfo.new(Speed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(TargetPos)})
        Tween:Play()
        TweenConnection = Tween
    end
    
    task.spawn(function()
        while _G.FastAttackAll do
            if IsClicking and IsActive then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                task.wait(0.002)
            else
                task.wait(0.05)
            end
        end
    end)
    
    while _G.FastAttackAll do
        local Character = LocalPlayer.Character
        if not Character then
            if IsActive then ForceReset() end
            task.wait(0.2)
            continue
        end
        
        local Root = Character:FindFirstChild("HumanoidRootPart")
        if not Root then
            if IsActive then ForceReset() end
            task.wait(0.2)
            continue
        end
        
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid or Humanoid.Health <= 0 then
            if IsActive then ForceReset() end
            task.wait(0.2)
            continue
        end
        
        local Enemies = workspace:FindFirstChild("Enemies")
        if not Enemies then
            if IsActive then ForceReset() end
            task.wait(0.2)
            continue
        end
        
        local HasEnemyNearby = false
        local ClosestEnemy = nil
        local ClosestDistance = math.huge
        local AllNearbyEnemies = {}
        
        for _, Enemy in ipairs(Enemies:GetChildren()) do
            if not _G.FastAttackAll then break end
            if not Enemy:IsA("Model") then continue end
            
            local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
            local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
            if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot then continue end
            
            local Distance = (Root.Position - EnemyRoot.Position).Magnitude
            if Distance <= 150 then
                HasEnemyNearby = true
                table.insert(AllNearbyEnemies, Enemy)
                if Distance < ClosestDistance then
                    ClosestDistance = Distance
                    ClosestEnemy = Enemy
                end
            end
        end
        
        if HasEnemyNearby and ClosestEnemy then
            if not IsActive then
                IsActive = true
                IsClicking = true
                CurrentTarget = ClosestEnemy
                TweenToEnemy(ClosestEnemy)
            end
            
            if CurrentTarget then
                local EnemyHumanoidCheck = CurrentTarget:FindFirstChildOfClass("Humanoid")
                local EnemyRootCheck = CurrentTarget:FindFirstChild("HumanoidRootPart")
                if not EnemyHumanoidCheck or EnemyHumanoidCheck.Health <= 0 or not EnemyRootCheck then
                    if ClosestEnemy ~= CurrentTarget then
                        CurrentTarget = ClosestEnemy
                        TweenToEnemy(ClosestEnemy)
                    end
                end
            end
            
            for _, Enemy in ipairs(AllNearbyEnemies) do
                if not _G.FastAttackAll then break end
                
                local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
                local EnemyRoot2 = Enemy:FindFirstChild("HumanoidRootPart")
                if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot2 then continue end
                
                local Distance = (Root.Position - EnemyRoot2.Position).Magnitude
                if Distance > 35 then continue end
                
                local TargetPart = Enemy:FindFirstChild("LeftFoot") or Enemy:FindFirstChild("RightFoot") or Enemy:FindFirstChild("Head") or EnemyRoot2
                
                local args = {
                    [1] = TargetPart,
                    [2] = {},
                    [4] = "079baa9c"
                }
                
                pcall(function()
                    AttackRemote:FireServer(unpack(args))
                end)
            end
        else
            if IsActive then ForceReset() end
        end
        
        task.wait()
    end
end) 
