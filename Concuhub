-- M1 Kitsune Fruit — Pure Remote No Delay
_G.KitsuneM1 = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LP = Players.LocalPlayer
local vector_create = Vector3.new

local function FireKitsuneM1()
    local char = LP.Character
    if not char then return end
    
    local fruit = char:FindFirstChild("Kitsune-Kitsune")
    if not fruit then return end
    
    local remote = fruit:FindFirstChild("LeftClickRemote")
    if not remote then return end
    
    local dir = char:GetPivot().LookVector * 300
    
    local args = {
        vector_create(dir.X, dir.Y, dir.Z),
        math.random(1, 4),
        true
    }
    
    pcall(function()
        remote:FireServer(unpack(args))
    end)
end

-- RenderStepped = nhanh nhất có thể, không delay
RunService.RenderStepped:Connect(function()
    if _G.KitsuneM1 then
        FireKitsuneM1()
    end
end)

print("[Kitsune M1] ON | No Click | No Delay")
