_G.FastAttackAll = true

task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local TweenService = game:GetService("TweenService")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer
    local AttackRemote = ReplicatedStorage.Modules.Net:FindFirstChild("RE/RegisterAttack")
    
    local IsClicking = false
    local CurrentTarget = nil
    local TweenConnection = nil
    local NoFallConnection = nil
    local OriginalGravity = workspace.Gravity
    local IsActive = false
    local OriginalWalkSpeed = 16
    local OriginalJumpPower = 50
    
    local function ForceReset()
        IsClicking = false
        CurrentTarget = nil
        IsActive = false
        
        if TweenConnection then
            TweenConnection:Cancel()
            TweenConnection = nil
        end
        
        if NoFallConnection then
            NoFallConnection:Disconnect()
            NoFallConnection = nil
        end
        
        workspace.Gravity = OriginalGravity
        
        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.WalkSpeed = OriginalWalkSpeed
                Humanoid.JumpPower = OriginalJumpPower
                Humanoid.PlatformStand = false
                Humanoid.AutoRotate = true
            end
            local Root = Char:FindFirstChild("HumanoidRootPart")
            if Root then
                Root.Velocity = Vector3.new(0, 0, 0)
                Root.RotVelocity = Vector3.new(0, 0, 0)
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") then
                    Part.CanCollide = true
                end
            end
        end
    end
    
    local function StartNoFall()
        if NoFallConnection then
            NoFallConnection:Disconnect()
        end
        
        workspace.Gravity = 0
        
        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                OriginalWalkSpeed = Humanoid.WalkSpeed
                OriginalJumpPower = Humanoid.JumpPower
                Humanoid.WalkSpeed = 0
                Humanoid.JumpPower = 0
                Humanoid.PlatformStand = true
                Humanoid.AutoRotate = false
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") and Part.Name ~= "HumanoidRootPart" then
                    Part.CanCollide = false
                end
            end
        end
        
        NoFallConnection = RunService.RenderStepped:Connect(function()
            if not IsActive then return end
            local Char = LocalPlayer.Character
            if Char and CurrentTarget then
                local Root = Char:FindFirstChild("HumanoidRootPart")
                local EnemyRoot = CurrentTarget:FindFirstChild("HumanoidRootPart")
                if Root and EnemyRoot then
                    local TargetCFrame = EnemyRoot.CFrame * CFrame.new(0, 10, 0)
                    Root.CFrame = TargetCFrame
                    Root.Velocity = Vector3.new(0, 0, 0)
                    Root.RotVelocity = Vector3.new(0, 0, 0)
                    Root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    Root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end
    
    local function TweenToEnemy(Enemy)
        if TweenConnection then
            TweenConnection:Cancel()
        end
        
        local Char = LocalPlayer.Character
        if not Char then return end
        
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if not Root then return end
        
        local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
        if not EnemyRoot then return end
        
        StartNoFall()
        
        local TargetPos = EnemyRoot.Position + Vector3.new(0, 10, 0)
        local Distance = (Root.Position - TargetPos).Magnitude
        local Speed = math.clamp(Distance / 250, 0.01, 0.05)
        
        local Tween = TweenService:Create(Root, TweenInfo.new(Speed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(TargetPos)})
        Tween:Play()
        TweenConnection = Tween
    end
    
    RunService.Heartbeat:Connect(function()
        if _G.FastAttackAll and IsActive and CurrentTarget then
            local EnemyRoot = CurrentTarget:FindFirstChild("HumanoidRootPart")
            if EnemyRoot then
                local ScreenPos, OnScreen = workspace.CurrentCamera:WorldToViewportPoint(EnemyRoot.Position)
                if OnScreen then
                    VirtualInputManager:SendMouseButtonEvent(ScreenPos.X, ScreenPos.Y, 0, true, game, 1)
                    VirtualInputManager:SendMouseButtonEvent(ScreenPos.X, ScreenPos.Y, 0, false, game, 1)
                end
                pcall(function()
                    AttackRemote:FireServer(0.5)
                end)
            end
        end
    end)
    
    while _G.FastAttackAll do
        local Character = LocalPlayer.Character
        if not Character then
            if IsActive then ForceReset() end
            task.wait(0.1)
            continue
        end
        
        local Root = Character:FindFirstChild("HumanoidRootPart")
        if not Root then
            if IsActive then ForceReset() end
            task.wait(0.1)
            continue
        end
        
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid or Humanoid.Health <= 0 then
            if IsActive then ForceReset() end
            task.wait(0.1)
            continue
        end
        
        local Enemies = workspace:FindFirstChild("Enemies")
        if not Enemies then
            if IsActive then ForceReset() end
            task.wait(0.1)
            continue
        end
        
        local HasEnemyNearby = false
        local ClosestEnemy = nil
        local ClosestDistance = math.huge
        
        for _, Enemy in ipairs(Enemies:GetChildren()) do
            if not _G.FastAttackAll then break end
            if not Enemy:IsA("Model") then continue end
            
            local EnemyHumanoid = Enemy:FindFirstChildOfClass("Humanoid")
            local EnemyRoot = Enemy:FindFirstChild("HumanoidRootPart")
            if not EnemyHumanoid or EnemyHumanoid.Health <= 0 or not EnemyRoot then continue end
            
            local Distance = (Root.Position - EnemyRoot.Position).Magnitude
            if Distance <= 200 then
                HasEnemyNearby = true
                if Distance < ClosestDistance then
                    ClosestDistance = Distance
                    ClosestEnemy = Enemy
                end
            end
        end
        
        if HasEnemyNearby and ClosestEnemy then
            if not IsActive then
                IsActive = true
                CurrentTarget = ClosestEnemy
                TweenToEnemy(ClosestEnemy)
            end
            
            if CurrentTarget then
                local EnemyHumanoidCheck = CurrentTarget:FindFirstChildOfClass("Humanoid")
                local EnemyRootCheck = CurrentTarget:FindFirstChild("HumanoidRootPart")
                if not EnemyHumanoidCheck or EnemyHumanoidCheck.Health <= 0 or not EnemyRootCheck then
                    CurrentTarget = ClosestEnemy
                    TweenToEnemy(ClosestEnemy)
                end
            end
        else
            if IsActive then ForceReset() end
        end
        
        task.wait()
    end
end) 
